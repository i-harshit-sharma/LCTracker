{
  "name": "workspace",
  "version": "0.6.0",
  "license": "MIT",
  "scripts": {
    "preinstall": "pnpm -v",
    "build": "pnpm run typecheck && pnpm -r --if-present run build",
    "typecheck:libs": "tsc --build",
    "typecheck": "pnpm run typecheck:libs && pnpm -r --filter \"./artifacts/**\" --filter \"./scripts\" --if-present run typecheck",
    "lint": "prettier --write .",
    "generate:api": "pnpm --filter @workspace/api-spec run codegen",
    "test:unit": "pnpm -r --if-present run test:unit",
    "test:e2e": "pnpm -r --if-present run test:e2e",
    "version-bump": "bash ./scripts/version-bump.sh",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,json,md,yml,yaml}": "prettier --write --ignore-unknown"
  },
  "private": true,
  "devDependencies": {
    "husky": "^9.1.7",
    "lint-staged": "^17.0.4",
    "prettier": "^3.8.1",
    "typescript": "~5.9.2"
  }
}
